font-family = JetBrainsMono Nerd Font
font-size = 15
theme = Cattpuccin Macchiato

shell-integration = zsh
macos-option-as-alt = true
theme = Catppuccin Mocha
window-padding-x = 10
window-padding-y = 10
cursor-style = block
copy-on-select = false
confirm-close-surface = false
background-opacity = 0.7
