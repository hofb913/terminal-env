########################################
# USER
########################################
[user]
    name = hofb913
    email = hofb913@icloud.me

[init]
    defaultBranch = main

########################################
# CORE SETTINGS
########################################
[core]
    editor = nvim
    pager = less -FRX
    autocrlf = input
    excludesfile = ~/.gitignore_global

########################################
# PULL / PUSH BEHAVIOR
########################################
[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true

########################################
# MERGE / REBASE IMPROVEMENTS
#####################`####  ###############
[merge]
    tool = vimdiff
    conflictStyle = zdiff3

[rebase]
    autoStash = true
    updateRefs = true

########################################
# DIFF / LOG FORMATTING
########################################
[diff]
    tool = nvimdiff

[log]
    date = iso

########################################
# BETTER COLORS
########################################
[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red
    new = green

########################################
# ALIASES (BIG PRODUCTIVITY BOOST)
########################################
[alias]
    st = status -sb
    co = checkout
    cb = checkout -b
    br = branch
    ci = commit
    ca = commit -a
    cm = commit -m
    amend = commit --amend --no-edit

    lg = log --oneline --graph --decorate --all
    lga = log --graph --pretty=format:'%C(yellow)%h%Creset %Cgreen%ad%Creset %C(auto)%d%Creset %s %C(blue)[%an]' --date=short

    df = diff
    dc = diff --cached

    last = log -1 HEAD
    unstage = reset HEAD --

    # safer force push
    pf = push --force-with-lease

########################################
# SAFETY FEATURES
########################################
[fetch]
    prune = true

[transfer]
    fsckObjects = true

[receive]
    fsckObjects = true

########################################
# CREDENTIALS (macOS)
########################################
[credential]
    helper = osxkeychain

########################################
# GLOBAL GITIGNORE FILE
########################################
# Path defined in [core].excludesfile:
# ~/.gitignore_global
#
# Example entries:
#   .DS_Store
#   *.swp
#   .vscode/
